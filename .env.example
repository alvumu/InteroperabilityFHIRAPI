# ─────────────────────────────────────────────────────────────────────────────
# Variables de entorno para InteroperabilityFHIRAPI
# Copia este archivo como .env y rellena los valores antes de iniciar el servidor.
# El archivo .env NO debe commitearse (ya está en .gitignore).
# ─────────────────────────────────────────────────────────────────────────────

# Clave de API de OpenAI (utilizada para los modelos de embeddings text-embedding-3-large, etc.)
OPENAI_API_KEY=sk-...

# Clave de API de Azure OpenAI (usada por los endpoints de identificación LLM con GPT)
AZURE_OPENAI_API=...

# URL del endpoint Azure OpenAI para el modelo GPT (p. ej. GPT-4 Vision)
GPT4V_ENDPOINT_FHIR=https://<resource>.openai.azure.com/openai/deployments/<deployment>/chat/completions?api-version=...

# Clave de API de Together AI (usada cuando llm_provider=Llama)
TOGETHER_API_KEY=...

# Ruta del archivo de log (opcional; por defecto: log.out)
LOG_FILE=log.out
